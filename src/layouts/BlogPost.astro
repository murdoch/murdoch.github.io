---
import type { CollectionEntry } from 'astro:content';
import { Picture, getImage } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'posts'>['data'];

const { title, description, pubDate, heroImage, heroAlt } = Astro.props;

const ogImage = await getImage({
  src: heroImage,
  width: 1200,
  height: 630,
  format: 'jpg',
});
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={ogImage.src} />
  </head>

  <body>
    <Header />

    <main>
      <article class="post">
        <header class="center">
          <p class="post-kicker"><FormattedDate date={pubDate} /></p>
          <h1>{title}</h1>
          <p class="post-dek">{description}</p>
        </header>

        <Picture
          src={heroImage}
          alt={heroAlt}
          width={800}
          height={450}
          formats={["avif", "webp", "jpg", "png"]} />

        <div class="post-body">
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
