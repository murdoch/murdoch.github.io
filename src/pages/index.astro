---
import { Picture } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_IMAGE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => { return data.published === true; })).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>

<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image={SITE_IMAGE} />
  </head>

  <body>
    <Header />

    <main>
      <h1 class="hidden">Stephen Murdoch</h1>

      <p class="bio">{SITE_DESCRIPTION}</p>

      <div class="grid">
        {
          posts.map((post, index) => (
            <article class={index === 0 ? 'is-featured' : ''}>
              <a href={`/posts/${post.id}/`} class="article-link">
                <div class="card-media">
                  <Picture
                    src={post.data.heroImage}
                    alt={post.data.heroAlt}
                    width={800}
                    height={450}
                    formats={["avif", "webp", "jpg", "png"]} />
                  {index === 0 && <span class="card-badge">Latest</span>}
                </div>

                <div class="card-body">
                  <FormattedDate date={post.data.pubDate} />
                  <h2>{post.data.title}</h2>
                  <p>{post.data.description}</p>
                  <span class="card-cta">
                    Read post
                    <span class="card-cta-arrow" aria-hidden="true">→</span>
                  </span>
                </div>
              </a>
            </article>
          ))
        }
      </div>
    </main>

    <Footer />
  </body>
</html>