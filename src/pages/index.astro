---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_IMAGE, HERO_SUB, BIO, PROJECTS } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => data.published === true)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const formatDate = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image={SITE_IMAGE} />
  </head>

  <body>
    <Header />

    <main class="page">
      <section class="hero">
        <div class="prompt">stephen-murdoch:~$ whoami</div>
        <h1>stephen murdoch<span class="cursor" aria-hidden="true"></span></h1>
        <p class="sub">{HERO_SUB}</p>
      </section>

      <section class="bio">
        <p class="s-label">about<span class="rule"></span></p>
        {BIO.map((p) => <p>{p}</p>)}
      </section>

      <section id="now">
        <p class="s-label">now<span class="rule"></span></p>
        <ul class="proj">
          {
            PROJECTS.map((p) => (
              <li>
                <a class="name" href={p.href}>{p.name}</a>
                <span class="desc">{p.desc}</span>
                <span class="meta">{p.status}</span>
              </li>
            ))
          }
        </ul>
      </section>

      <section id="writing">
        <p class="s-label">writing<span class="rule"></span></p>
        <ul class="posts">
          {
            posts.map((post) => (
              <li>
                <a href={`/posts/${post.id}/`}>
                  <span class="date">{formatDate(post.data.pubDate)}</span>
                  <span>
                    <span class="title">{post.data.title}</span>
                    <span class="desc">{post.data.description}</span>
                  </span>
                  <span class="arrow">→</span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>

    <Footer />
  </body>
</html>
